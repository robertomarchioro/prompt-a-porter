# Prompt a Porter — Variabili d'ambiente
# Copia questo file in .env e personalizza i valori.
# NON committare mai il file .env con valori reali.

# === Server Sync ===
# Email dell'admin iniziale (creato al primo avvio del server)
PAP_ADMIN_EMAIL=admin@example.com

# Porta del server sync
PAP_SERVER_PORT=8443

# Path del database SQLite del server
PAP_DB_PATH=./data/papsync.db

# Segreto per firma JWT (generare con: openssl rand -hex 32)
PAP_JWT_SECRET=cambiami-con-un-valore-sicuro

# === Client (opzionale, per dev) ===
# Livello di log: trace | debug | info | warn | error
PAP_LOG_LEVEL=debug
