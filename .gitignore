# === Dipendenze ===
node_modules/
.pnpm-store/
# Repo usa pnpm: package-lock.json e yarn.lock vanno esclusi
package-lock.json
yarn.lock

# === Build output ===
dist/
build/
out/
*.tsbuildinfo

# === Tauri / Rust ===
apps/client/src-tauri/target/
apps/client/src-tauri/gen/
# Cargo.lock dell'app Tauri è committato per riproducibilità e sicurezza (vedi strategia CI: lock+--locked+toolchain pin+dependabot+canary).
*.rs.bk

# === Go ===
apps/server/papsync
apps/server/papsync.exe
apps/server/vendor/
# CLI `pap` cross-compilata in CI e bundlata come risorsa nell'installer
# Windows in una sottocartella dedicata bin/ (evita la collisione col binario
# GUI omonimo; vedi release.yml + tauri.windows.conf.json). Mai committata.
apps/client/src-tauri/bin/
apps/client/src-tauri/pap.exe

# === Ambiente ===
.env
.env.local
.env.*.local
!.env.example

# === OS ===
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# === IDE ===
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# === Claude Code (config locale per-operatore, mai condivisa) ===
# settings.local.json contiene allowlist di permessi e override ambiente
# specifici della macchina: va tenuto fuori dallo stato condiviso del repo.
.claude/settings.local.json

# === Log ===
*.log
npm-debug.log*
pnpm-debug.log*

# === Test / Coverage ===
coverage/
.nyc_output/

# === Vault (mai committare DB cifrati) ===
*.db
*.sqlite
*.sqlite3
!apps/server/testdata/*.db
