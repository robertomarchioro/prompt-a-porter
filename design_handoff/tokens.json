{
  "$schema": "https://promptvault.local/tokens.schema.json",
  "meta": {
    "name": "PromptVault Design Tokens",
    "version": "0.1.0",
    "license": "GPL-2.0",
    "notes": "Mirror JSON dei token CSS. Consumabile da Svelte 5 (es. import + bind a CSS vars in runtime per persistere preferenze utente). Ogni token con valore dark/light vive in `themes.{tone}.{theme}`."
  },
  "type": {
    "fontUI": "-apple-system, BlinkMacSystemFont, 'Segoe UI Variable', 'Segoe UI', Inter, Roboto, 'Helvetica Neue', Arial, sans-serif",
    "fontMono": "'JetBrains Mono', 'SF Mono', 'Cascadia Code', 'Roboto Mono', Consolas, 'Liberation Mono', monospace",
    "scale": {
      "xs":  "12px",
      "sm":  "13px",
      "base":"14px",
      "md":  "15px",
      "lg":  "16px",
      "xl":  "18px",
      "2xl": "22px",
      "3xl": "28px"
    },
    "lineHeight":   { "tight": 1.2, "snug": 1.35, "normal": 1.5, "loose": 1.65 },
    "weight":       { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "tracking":     { "tight": "-0.01em", "normal": "0", "wide": "0.02em", "caps": "0.06em" }
  },
  "space":  { "0":"0","1":"4px","2":"8px","3":"12px","4":"16px","5":"24px","6":"32px","7":"48px","8":"64px" },
  "radius": { "sm":"6px","md":"10px","lg":"14px","full":"999px" },
  "border": { "thin":"1px","regular":"1.5px","thick":"2px" },
  "z": {
    "base":0,"sticky":100,"dropdown":200,"overlay":300,
    "modal":400,"toast":500,"tooltip":600,"palette":700
  },
  "motion": {
    "duration": { "fast":"100ms","normal":"150ms","slow":"200ms" },
    "easing":   {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "emphasis": "cubic-bezier(0.3, 0, 0, 1)"
    }
  },
  "accent": {
    "private": {
      "dark":  { "base":"oklch(0.78 0.14 78)",  "strong":"oklch(0.85 0.15 80)",  "soft":"oklch(0.78 0.14 78 / 0.18)", "on":"oklch(0.18 0.04 78)"  },
      "light": { "base":"oklch(0.62 0.14 70)",  "strong":"oklch(0.55 0.15 68)",  "soft":"oklch(0.62 0.14 70 / 0.16)", "on":"oklch(0.99 0.005 70)" }
    },
    "team": {
      "dark":  { "base":"oklch(0.70 0.18 290)", "strong":"oklch(0.78 0.18 292)", "soft":"oklch(0.70 0.18 290 / 0.18)","on":"oklch(0.18 0.04 290)" },
      "light": { "base":"oklch(0.55 0.20 290)", "strong":"oklch(0.48 0.21 290)", "soft":"oklch(0.55 0.20 290 / 0.14)","on":"oklch(0.99 0.005 290)" }
    }
  },
  "semantic": {
    "success": { "base":"oklch(0.72 0.16 155)", "soft":"oklch(0.72 0.16 155 / 0.16)" },
    "warning": { "base":"oklch(0.80 0.15 75)",  "soft":"oklch(0.80 0.15 75 / 0.16)"  },
    "danger":  { "base":"oklch(0.65 0.21 25)",  "soft":"oklch(0.65 0.21 25 / 0.16)"  },
    "info":    { "base":"oklch(0.72 0.13 235)", "soft":"oklch(0.72 0.13 235 / 0.16)" }
  },
  "themes": {
    "slate": {
      "dark": {
        "bg":      { "canvas":"oklch(0.18 0.012 250)","surface":"oklch(0.21 0.014 250)","raised":"oklch(0.245 0.014 250)","overlay":"oklch(0.30 0.014 250)","input":"oklch(0.16 0.012 250)","scrim":"oklch(0.10 0.01 250 / 0.55)" },
        "border":  { "subtle":"oklch(0.30 0.014 250)","default":"oklch(0.36 0.016 250)","strong":"oklch(0.46 0.018 250)" },
        "text":    { "strong":"oklch(0.97 0.01 250)","default":"oklch(0.88 0.012 250)","muted":"oklch(0.66 0.014 250)","subtle":"oklch(0.50 0.014 250)","disabled":"oklch(0.40 0.012 250)" },
        "shadow":  { "sm":"0 1px 2px oklch(0 0 0 / 0.30)","md":"0 4px 12px oklch(0 0 0 / 0.35), 0 1px 2px oklch(0 0 0 / 0.30)","lg":"0 16px 40px oklch(0 0 0 / 0.45), 0 4px 8px oklch(0 0 0 / 0.30)" }
      },
      "light": {
        "bg":     { "canvas":"oklch(0.985 0.003 250)","surface":"oklch(1.000 0 0)","raised":"oklch(1.000 0 0)","overlay":"oklch(0.945 0.008 250)","input":"oklch(0.975 0.005 250)","scrim":"oklch(0.20 0.012 250 / 0.30)" },
        "border": { "subtle":"oklch(0.92 0.008 250)","default":"oklch(0.86 0.010 250)","strong":"oklch(0.74 0.012 250)" },
        "text":   { "strong":"oklch(0.18 0.012 250)","default":"oklch(0.28 0.012 250)","muted":"oklch(0.48 0.012 250)","subtle":"oklch(0.62 0.012 250)","disabled":"oklch(0.74 0.010 250)" },
        "shadow": { "sm":"0 1px 2px oklch(0.20 0.01 250 / 0.06)","md":"0 4px 12px oklch(0.20 0.01 250 / 0.10), 0 1px 2px oklch(0.20 0.01 250 / 0.05)","lg":"0 16px 40px oklch(0.20 0.01 250 / 0.16), 0 4px 8px oklch(0.20 0.01 250 / 0.08)" }
      }
    },
    "stone": {
      "dark":  {
        "bg":     { "canvas":"oklch(0.185 0.007 60)","surface":"oklch(0.215 0.008 60)","raised":"oklch(0.250 0.009 60)","overlay":"oklch(0.305 0.010 60)","input":"oklch(0.165 0.007 60)","scrim":"oklch(0.10 0.005 60 / 0.55)" },
        "border": { "subtle":"oklch(0.305 0.010 60)","default":"oklch(0.365 0.012 60)","strong":"oklch(0.465 0.014 60)" },
        "text":   { "strong":"oklch(0.97 0.006 60)","default":"oklch(0.88 0.008 60)","muted":"oklch(0.66 0.010 60)","subtle":"oklch(0.50 0.010 60)","disabled":"oklch(0.40 0.008 60)" },
        "shadow": { "sm":"0 1px 2px oklch(0 0 0 / 0.30)","md":"0 4px 12px oklch(0 0 0 / 0.35), 0 1px 2px oklch(0 0 0 / 0.30)","lg":"0 16px 40px oklch(0 0 0 / 0.45), 0 4px 8px oklch(0 0 0 / 0.30)" }
      },
      "light": {
        "bg":     { "canvas":"oklch(0.985 0.004 60)","surface":"oklch(1.000 0 0)","raised":"oklch(1.000 0 0)","overlay":"oklch(0.945 0.008 60)","input":"oklch(0.975 0.005 60)","scrim":"oklch(0.20 0.008 60 / 0.30)" },
        "border": { "subtle":"oklch(0.92 0.008 60)","default":"oklch(0.86 0.010 60)","strong":"oklch(0.74 0.012 60)" },
        "text":   { "strong":"oklch(0.18 0.010 60)","default":"oklch(0.28 0.010 60)","muted":"oklch(0.48 0.010 60)","subtle":"oklch(0.62 0.010 60)","disabled":"oklch(0.74 0.008 60)" },
        "shadow": { "sm":"0 1px 2px oklch(0.20 0.01 60 / 0.06)","md":"0 4px 12px oklch(0.20 0.01 60 / 0.10), 0 1px 2px oklch(0.20 0.01 60 / 0.05)","lg":"0 16px 40px oklch(0.20 0.01 60 / 0.16), 0 4px 8px oklch(0.20 0.01 60 / 0.08)" }
      }
    },
    "zinc": {
      "dark":  {
        "bg":     { "canvas":"oklch(0.185 0.002 270)","surface":"oklch(0.215 0.002 270)","raised":"oklch(0.250 0.002 270)","overlay":"oklch(0.305 0.003 270)","input":"oklch(0.165 0.002 270)","scrim":"oklch(0.10 0.001 270 / 0.55)" },
        "border": { "subtle":"oklch(0.305 0.003 270)","default":"oklch(0.365 0.003 270)","strong":"oklch(0.465 0.004 270)" },
        "text":   { "strong":"oklch(0.97 0.001 270)","default":"oklch(0.88 0.002 270)","muted":"oklch(0.66 0.003 270)","subtle":"oklch(0.50 0.003 270)","disabled":"oklch(0.40 0.002 270)" },
        "shadow": { "sm":"0 1px 2px oklch(0 0 0 / 0.30)","md":"0 4px 12px oklch(0 0 0 / 0.35), 0 1px 2px oklch(0 0 0 / 0.30)","lg":"0 16px 40px oklch(0 0 0 / 0.45), 0 4px 8px oklch(0 0 0 / 0.30)" }
      },
      "light": {
        "bg":     { "canvas":"oklch(0.985 0.001 270)","surface":"oklch(1.000 0 0)","raised":"oklch(1.000 0 0)","overlay":"oklch(0.945 0.002 270)","input":"oklch(0.975 0.001 270)","scrim":"oklch(0.20 0.002 270 / 0.30)" },
        "border": { "subtle":"oklch(0.92 0.002 270)","default":"oklch(0.86 0.003 270)","strong":"oklch(0.74 0.003 270)" },
        "text":   { "strong":"oklch(0.18 0.002 270)","default":"oklch(0.28 0.002 270)","muted":"oklch(0.48 0.003 270)","subtle":"oklch(0.62 0.003 270)","disabled":"oklch(0.74 0.002 270)" },
        "shadow": { "sm":"0 1px 2px oklch(0.20 0.001 270 / 0.06)","md":"0 4px 12px oklch(0.20 0.001 270 / 0.10), 0 1px 2px oklch(0.20 0.001 270 / 0.05)","lg":"0 16px 40px oklch(0.20 0.001 270 / 0.16), 0 4px 8px oklch(0.20 0.001 270 / 0.08)" }
      }
    }
  }
}
