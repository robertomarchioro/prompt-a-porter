{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Prompt a Porter",
  "version": "0.8.32",
  "identifier": "com.pap.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev:frontend",
    "beforeBuildCommand": "pnpm build:frontend"
  },
  "app": {
    "windows": [
      {
        "label": "libreria",
        "title": "Prompt a Porter",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      },
      {
        "label": "palette",
        "title": "",
        "width": 640,
        "height": 480,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["Italian"]
      }
    },
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1"]
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1NDk4MTBCQjBFQzc5MwpSV1NUeHc2N0VKaFVCL1l0OERJampkK2JRZWlkNFVNN2RlT3dOM2xNKzduNDRaUnhTL0hkeWF2Rwo=",
      "endpoints": [
        "https://github.com/robertomarchioro/prompt-a-porter/releases/latest/download/latest.json"
      ]
    }
  }
}
