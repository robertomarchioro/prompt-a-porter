{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/crates/tauri/schema.json",
  "identifier": "default",
  "description": "Permessi base per Prompt a Porter",
  "windows": ["libreria", "palette"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-center",
    "core:window:allow-is-visible",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister"
  ]
}
